generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String
  city       String?
  state      String?
  assessoria String?
  bio          String?  // bio curta do perfil (máx 150 chars, validado no DTO)
  featuredMedalIds String[] @default([]) // ids de UserChallenge (medalhas) fixadas no perfil
  avatarUrl    String?
  weightKg     Float?
  heightCm     Int?
  zipCode      String?
  street       String?
  streetNumber String?
  complement   String?
  neighborhood String?
  deliveryCity  String?
  deliveryState String?
  pushToken     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities       Activity[]
  userChallenges   UserChallenge[]
  posts            Post[]
  reactions        Reaction[]
  comments         Comment[]
  following        Follow[]        @relation("following") // Follows que ESTE user criou (quem ele segue)
  followers        Follow[]        @relation("followers") // Follows que apontam pra ESTE user (quem o segue)
  notifications      Notification[] @relation("notifRecipient") // notificações recebidas
  notificationsActed Notification[] @relation("notifActor")     // notificações que ESTE user causou
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String // quem segue
  followingId String // quem é seguido
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id])
  following User @relation("followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  RANK_PASSED
}

model Notification {
  id         String           @id @default(cuid())
  userId     String // destinatário
  type       NotificationType
  actorId    String? // quem causou (curtiu/comentou/seguiu/ultrapassou)
  targetType String? // 'post' | 'activity' | 'ranking' | null
  targetId   String? // id do post/atividade (deep-link) ou scope do ranking
  title      String
  body       String
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user  User  @relation("notifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("notifActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Challenge {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  title     String
  goalKm    Float
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())

  userChallenges UserChallenge[]

  @@unique([year, month])
}

model UserChallenge {
  id          String      @id @default(cuid())
  userId      String
  challengeId String
  medalStatus MedalStatus @default(PROGRESS)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
}

enum MedalStatus {
  PROGRESS
  SHIPPED
  DELIVERED
  MISSED
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  body      String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Reaction {
  id         String   @id @default(cuid())
  userId     String
  targetType String
  targetId   String
  type       String   @default("like") // curtida única (coração); reações antigas fire/clap também contam como curtida
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  targetType String
  targetId   String
  body       String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([targetType, targetId, createdAt])
}

model Activity {
  id         String   @id @default(cuid())
  userId     String
  stravaId   Int?     @unique // legado: integração Strava removida
  externalId String?  @unique // uuid do HKWorkout (Apple Health) p/ dedup de import
  title      String
  distanceKm Float
  pace       String?
  source     String
  counts         Boolean  @default(true)
  skipReason     String?
  startedAt      DateTime
  durationSec    Int?
  pauseSec       Int? // tempo total em pausa (subtrai-se ao mostrar "tempo movimento")
  routePolyline  String? // traçado GPS encodado (Google polyline) — feed/detalhe
  // Stats derivados dos coords do tracker; nullable porque corridas antigas não têm.
  elevationGainM Int?
  elevationLossM Int?
  maxElevationM  Int?
  maxSpeedKph    Float?
  splits         Json? // array { km, paceSec, elevDelta } por split de 1km
  avgHeartRate   Int?
  maxHeartRate   Int?
  caloriesBurned Float?
  feeling        Int?
  surface        String?
  note           String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

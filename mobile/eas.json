{
  "cli": {
    "version": ">= 19.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://nutristreetrun-production.up.railway.app",
        "EXPO_PUBLIC_CHECKOUT_URL": "https://checkout.example.com/nutristreetrun"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://nutristreetrun-production.up.railway.app",
        "EXPO_PUBLIC_CHECKOUT_URL": "https://checkout.example.com/nutristreetrun"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

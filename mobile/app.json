{
  "expo": {
    "name": "NutriStreet Run",
    "slug": "nutristreetrun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1110"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutristreetrun.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E1110"
      },
      "package": "com.nutristreetrun.app",
      "edgeToEdgeEnabled": true
    },
    "scheme": "nutristreetrun",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}

{
  "expo": {
    "name": "NutriStreet Run",
    "slug": "nutristreetrun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1110"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutristreetrun.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Usado para enviar foto de perfil e publicar no feed.",
        "NSCameraUsageDescription": "Usado para tirar foto de perfil e publicar no feed.",
        "NSHealthShareUsageDescription": "Usado para importar suas corridas automaticamente.",
        "NSHealthUpdateUsageDescription": "Usado para registrar atividades no Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E1110"
      },
      "package": "com.nutristreetrun.app",
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.RECEIVE_BOOT_COMPLETED", "android.permission.VIBRATE"]
    },
    "scheme": "nutristreetrun",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5FB8A8",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Usado para enviar foto de perfil e publicar no feed.",
          "cameraPermission": "Usado para tirar foto de perfil e publicar no feed."
        }
      ]
    ]
  }
}

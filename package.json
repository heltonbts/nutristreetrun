{
  "name": "nutristreetrun",
  "private": true,
  "workspaces": [
    "backend",
    "mobile"
  ],
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0"
  },
  "lint-staged": {
    "backend/**/*.{ts,json}": [
      "npm run lint --prefix backend",
      "npm run format --prefix backend"
    ],
    "mobile/**/*.{ts,tsx,json}": [
      "npm run lint --prefix mobile"
    ]
  }
}
